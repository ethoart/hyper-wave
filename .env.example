# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# MONGO_URI: The MongoDB connection string
MONGO_URI=""

# JWT_SECRET: Secret for signing tokens
JWT_SECRET="super-secret-default-key-change-me"

# BINANCE_API_KEY (Optional for public data)
BINANCE_API_KEY=""

# BINANCE_SECRET_KEY (Required for placing trades)
BINANCE_SECRET_KEY=""

# VITE_PRO_CONTRACT_ADDRESS: Deployed Subscription Smart Contract Address (Base Network)
VITE_PRO_CONTRACT_ADDRESS=""

# VITE_USDC_ADDRESS: USDC Token Address on Base Network
VITE_USDC_ADDRESS="0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913"

# TUNNEL_TOKEN: Cloudflare Zero Trust Tunnel Token (if using Cloudflare Tunnels)
TUNNEL_TOKEN=""
